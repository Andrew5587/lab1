<Window x:Class="lab7.AddProductWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Додати товар" Height="300" Width="400" WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Text="Назва:" VerticalAlignment="Center" Margin="0,10"/>
        <TextBox x:Name="tbName" Grid.Column="1" Margin="0,10" Padding="5"/>

        <TextBlock Text="Ціна:" Grid.Row="1" VerticalAlignment="Center" Margin="0,10"/>
        <TextBox x:Name="tbPrice" Grid.Row="1" Grid.Column="1" Margin="0,10" Padding="5"/>

        <CheckBox x:Name="cbInStock" Content="В наявності на складі" Grid.Row="2" Grid.ColumnSpan="2" Margin="0,10"/>

        <StackPanel Grid.Row="4" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="btnSave" Content="Зберегти" Width="100" Margin="10,0,0,0" Click="btnSave_Click"/>
            <Button x:Name="btnCancel" Content="Скасувати" Width="100" Margin="10,0,0,0" Click="btnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>