<Window x:Class="lab8.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:lab8.ViewModels"
        Title="Магазин електроніки" 
        Height="500" Width="850" 
        MinHeight="400" MinWidth="600"> 
    
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="5,10"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="10,0"/>
        </Style>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" MinHeight="60"/> 
            <RowDefinition Height="*"/> 
        </Grid.RowDefinitions>
        
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/> 
            <ColumnDefinition Width="3*"/> 
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.ColumnSpan="2" Background="#E0E0E0" BorderThickness="0,0,0,1" BorderBrush="#BCBCBC">
            <TextBlock Text="Керування складом (WPF)" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10" FontWeight="Bold"/>
        </Border>

        <Border Grid.Row="1" Grid.Column="0" Background="#F8F8F8" BorderThickness="0,0,1,0" BorderBrush="#BCBCBC">
            <ScrollViewer VerticalScrollBarVisibility="Auto"> 
                <StackPanel Margin="15">
                    <TextBlock Text="Дії з товарами:" HorizontalAlignment="Center" Margin="0,0,0,20" FontWeight="SemiBold" FontSize="16"/>
                    <Button x:Name="btnAdd" Content="Додати" Command="{Binding AddCommand}"/>
                    <Button x:Name="btnEdit" Content="Редагувати"/>
                    <Button x:Name="btnDelete" Content="Видалити" Command="{Binding DeleteCommand}"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Grid Grid.Row="1" Grid.Column="1" Margin="15">
            <DataGrid x:Name="dgProducts" 
                      ItemsSource="{Binding Products}"
                      SelectedItem="{Binding SelectedProduct}"
                      AutoGenerateColumns="False" 
                      CanUserAddRows="False" 
                      SelectionMode="Single"
                      HorizontalAlignment="Stretch" 
                      VerticalAlignment="Stretch"
                      FontSize="14">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Назва" Binding="{Binding Name}" Width="2*"/>
                    <DataGridTextColumn Header="Ціна" Binding="{Binding Price}" Width="1*"/>
                    <DataGridCheckBoxColumn Header="Склад" Binding="{Binding InStock}" Width="Auto"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</Window>